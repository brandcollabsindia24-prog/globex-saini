PORT=5005
MONGO_URI=your-production-mongodb-uri
JWT_SECRET=replace-with-a-strong-secret

# Comma-separated origins allowed to call backend from browser
CORS_ORIGINS=https://theglobex.live,https://www.theglobex.live
FRONTEND_URL=https://theglobex.live

ENABLE_DB_FALLBACK=false
ALLOW_SERVER_WITHOUT_DB=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="Globex <no-reply@theglobex.live>"

